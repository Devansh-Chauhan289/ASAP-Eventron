# ───────────────────────── Core ─────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SWAGGER_ENABLED=true

# ──────────────────────── Database ──────────────────────
# PostgreSQL (RDS in prod). Prisma is the only ORM; PostgreSQL is the system of record.
DATABASE_URL=postgresql://asap:asap@localhost:5432/asap?schema=public

# ───────────────────────── Redis ────────────────────────
# Two logical roles: cache (allkeys-lru) and queues (noeviction). One instance OK for dev.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ───────────────────────── Auth ─────────────────────────
# RS256 in prod (Secrets Manager). HS256 secret acceptable for local dev.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ──────────────────────── Stripe ────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ──────────────────── Providers (sandbox) ───────────────
TICKETMASTER_API_KEY=tm_sandbox_xxx
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2

# ─────────────────── Notifications ──────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=no-reply@asap.app
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ──────────────────────── Misc ──────────────────────────
OUTBOX_RELAY_INTERVAL_MS=1000
LOG_LEVEL=debug
